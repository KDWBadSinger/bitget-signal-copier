PORT=3000

# Telegram Bot API
TELEGRAM_BOT_TOKEN=
# Optional comma-separated chat IDs. Leave empty to allow every chat the bot can read.
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_POLLING_ENABLED=true
TELEGRAM_WEBHOOK_SECRET=

# Bitget API
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
BITGET_BASE_URL=https://api.bitget.com
BITGET_DRY_RUN=true
BITGET_DEMO_TRADING=false

# Trading defaults
AUTO_TRADING_ENABLED=false
DEFAULT_ORDER_SIZE=
DEFAULT_QUOTE=USDT
MAX_NOTIONAL_USDT=
