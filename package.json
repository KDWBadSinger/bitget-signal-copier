{
  "name": "bitget-signal-copier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"python -m server.app\" \"vite --host 0.0.0.0 --port 5173\"",
    "dev:server": "python -m server.app",
    "dev:client": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "check": "tsc -p tsconfig.client.json --noEmit && python -m compileall -q server",
    "start": "python -m server.app"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5"
  }
}
